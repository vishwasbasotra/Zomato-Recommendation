# LLM provider (openai, anthropic, ollama, gemini, etc.)
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
LLM_API_KEY=
LLM_TIMEOUT_SEC=60
LLM_MAX_RETRIES=1

# Data
DATA_PATH=data/processed/restaurants.parquet

# Recommendation limits
MAX_CANDIDATES=10
TOP_K_DEFAULT=5

# Budget bands (cost for two, INR)
BUDGET_LOW_MAX=400
BUDGET_MEDIUM_MAX=800

# Prompt / input limits
MAX_REVIEW_CHARS=200
MAX_ADDITIONAL_PREF_CHARS=500

# Logging
LOG_LEVEL=INFO
